# WhaleComment Backend — 环境变量模板
# 复制此文件为 .env，填入真实值

# Supabase（必需 — 当前占位符是假值！）
SUPABASE_URL=https://sxsmjfkxllepntgzfqbl.supabase.co
# ⚠️ 必须用 Service Role Key（不是 anon key）
# 从 https://supabase.com/dashboard/project/sxsmjfkxllepntgzfqbl/settings/api 获取
SUPABASE_SERVICE_KEY=your_real_service_role_key_here

# Render/Server
NODE_ENV=production
PORT=10000

# 管理员密码（默认，可不改）
ADMIN_TOKEN=wc_admin_2026_secret_token

# 豆包 AI（可选，用于 /api/scripts/generate-comment）
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-smart-router-250928
