{
  "name": "whalecomment",
  "version": "1.1.4",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win dir",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "dependencies": {
    "puppeteer-core": "^21.11.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.whalecomment.app",
    "productName": "WhaleComment",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "worker.js",
      "preload.js",
      "index.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "wc_profile",
        "to": "wc_profile",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
